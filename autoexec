// __________________________________________________________________________________________________________________________________________________________________________
//
// Network Settings - these settings are designed to get that
// absolute edge in competitive TF2. Whilst net settings aren't an
// integral part of an FPS config file, they are the life of competitive
// TF2, all settings were copied from Comanglia's Config file, under "Netsettings.cfg".
// __________________________________________________________________________________________________________________________________________________________________________

rate 80000             // Rate should be 80% of your stable upload speed in bytes per second.
                       // This assumes you have approximately 1MBps upload.
// rate 196608         // 1.57 MBps default rate from CS:GO.
// rate 1048576        // Maxes out your bandwidth so no data is choked.
cl_cmdrate 66          // Sends updates to the server 66 times a second.
cl_updaterate 66       // Receives updates from the server 66 times a second.
cl_lagcompensation 1
cl_pred_optimize 2
cl_interp_ratio 1      // Set to 2 if you play on Wi-Fi or have packet loss.
cl_interp 0.0151515    // Pushes your hitboxes as close to the models as possible.
                       // cl_interp 0.0151515 - Projectile based classes.
                       // cl_interp 0.030303  - Hitscan based classes.
cl_smooth 0            // Disables artificial smoothing so player movement is exact.
cl_smoothtime 0.01

net_splitpacket_maxrate 196608
net_splitrate 1 				        // How many packets to split per frame.
net_maxcleartime 0.020346
net_compresspackets 1 			    // Compress packets to reduce network latency on fast CPUs.
net_maxroutable 1200 			      // This is the "balanced" option from mastercomms if you have issues
									              // setting this to 956 may help.
net_maxfragments 1200 			    // This is the "balanced" option from mastercomms if you have issues
									              // setting this to 956 may help.
net_compresspackets_minsize 128 // This is the "balanced" option from mastercomms
									              // other recommended options are 957 and 1261.
hud_escort_interp 0.1 	        // Smooth out networked HUD updates over slightly less time.
cl_timeout 70 			            // Max client timeout.
net_maxpacketdrop 1000 	        // Use faster packet drop threshold.
net_maxfilesize 64 		          // Max out file upload size for extra content.
tf_steam_workshop_query_timeout 5
sv_parallel_sendsnapshot 1 		  // Send snapshots to clients in parallel.
cl_downloadfilter all
tf_mm_custom_ping 120 		    // The ping tolerance for matchmaking.
tf_mm_custom_ping_enabled 1 	// Enable custom ping tolerance.
tf_mm_debug_level 0 			    // Remove matchmaking debug output.
tf_mm_partyclient_debug 1 	  // Enable party debug output.
tf_party_ignore_invites 1  	  // Ignore party invites.
tf_party_join_request_mode 1 	// Mode for party join requests.
tf_party_keep_on_same_team 0 	// Do not enforce parties being on the same team.

tf_datacenter_ping_debug 1   	// Turn on debugging for server routing.
tf_datacenter_ping_dump 1		  // Dump server routing debug info.
tf_mm_dump_match_invites 1 		// Show current match invites.
cl_showhelp 0
cl_ask_blacklist_opt_out 1
cl_ask_favorite_opt_out 1

sb_dontshow_maxplayer_warning 1

